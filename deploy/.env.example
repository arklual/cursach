# Скопируй в .env на сервере и заполни реальными значениями.
# Никогда не коммить настоящий .env в git.

# Владелец образа в GHCR (lowercase!). Пример: arklual или strevesuksess
GHCR_OWNER=CHANGE_ME

# Теги образов — обычно ставит CI (git SHA), но можно и руками
BACKEND_TAG=latest
FRONTEND_TAG=latest

# Postgres
POSTGRES_DB=a11a
POSTGRES_USER=a11a
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# MinIO
MINIO_BUCKET=a11a-blobs
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# SSL (пути на хосте к сертификату и ключу)
SSL_CERT_PATH=/opt/kursach/ssl/tls.crt
SSL_KEY_PATH=/opt/kursach/ssl/tls.key

# Basic auth для фронта (защита от случайных посетителей / лёгкого DDoS).
# Сам файл .htpasswd генерируется и заливается на сервер CI/CD (workflow frontend.yml)
# из GitHub Secrets FRONTEND_BASIC_AUTH_USER / FRONTEND_BASIC_AUTH_PASSWORD.
# Webhook (/v1/webhook/*) намеренно остаётся открытым.
HTPASSWD_PATH=/opt/kursach/.htpasswd
